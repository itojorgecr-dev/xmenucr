# ─────────────────────────────────────────────────────────────
# XMenú CR — Variables de entorno
# ─────────────────────────────────────────────────────────────
#
# Copiá este archivo a `.env.local` para desarrollo, o cargá estas
# variables en el panel de Vercel (Settings → Environment Variables).
#
# Las VITE_* son config PÚBLICA del cliente Firebase (no son secretas:
# se sirven al navegador). Las secretas van SOLO en Vercel y NO llevan
# el prefijo VITE_ (ver bloque de abajo).

# ── Firebase (cliente / público) ──
# Se obtienen en Firebase Console → Configuración del proyecto →
# Tus apps → App web → Configuración del SDK.
VITE_FIREBASE_API_KEY=AIzaSy_pega_tu_api_key
VITE_FIREBASE_AUTH_DOMAIN=xmenucr.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=xmenucr
VITE_FIREBASE_STORAGE_BUCKET=xmenucr.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=000000000000
VITE_FIREBASE_APP_ID=1:000000000000:web:0000000000000000000000

# UID del superadmin (Jorge). Habilita el panel de superadmin.
VITE_SUPERADMIN_UID=pega_el_uid_de_jorge

# ── Secretas — SOLO en Vercel, NUNCA con prefijo VITE_ (fase siguiente) ──
# FIREBASE_SERVICE_ACCOUNT={...json de la cuenta de servicio...}
# RESEND_API_KEY=re_...
# ANTHROPIC_API_KEY=sk-ant-...
